# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Virtual environment
.venv/

# Lock file (regenerable)
uv.lock

# Data (ignore everything, keep folder structure via .gitkeep)
data/raw/*
!data/raw/.gitkeep
catboost_info/

# Notebooks checkpoints & executed copies
.ipynb_checkpoints/
notebooks/*_executed.ipynb

# IDE
.vscode/
.idea/

# OS
.DS_Store

# Outputs (model artifacts, predictions, submissions) — keep only required files
outputs/*
!outputs/feature_selection_v5_fr.json
!outputs/uk_feature_research.json
!outputs/submission_attack_averaged.csv
